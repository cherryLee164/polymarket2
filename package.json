{
  "name": "ploymarket",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "monitor": "node scripts/monitor-launcher.js",
    "monitor:1h": "node scripts/monitor.js",
    "monitor:4h": "set MONITOR_VARIANT=4h&& set MONITOR_WINDOW_HOURS=4&& set MONITOR_WINDOW_MINUTES=240&& node scripts/monitor.js",
    "monitor:15m": "set MONITOR_VARIANT=15m&& set MONITOR_WINDOW_HOURS=0.25&& set MONITOR_WINDOW_MINUTES=15&& node scripts/monitor.js",
    "monitor:5m": "set MONITOR_VARIANT=5m&& set MONITOR_WINDOW_HOURS=0.0833333333&& set MONITOR_WINDOW_MINUTES=5&& node scripts/monitor.js",
    "weather:sync": "node scripts/weather_sync_launcher.js",
    "weather:sync:worker": "node scripts/weather_sync.js",
    "weather:settlement": "node scripts/weather_settlement_worker.js",
    "weather:settlement:once": "node scripts/weather_settlement_worker.js --once",
    "order": "node scripts/order-launcher.js",
    "order:recovery": "node scripts/order_recovery_launcher.js",
    "settlement:recovery": "node scripts/settlement_recovery_launcher.js",
    "settlement:once": "node scripts/settlement_recovery_launcher.js --once",
    "order:1h": "set ORDER_VARIANT=1h&& python scripts/order.py",
    "order:4h": "set ORDER_VARIANT=4h&& python scripts/order.py",
    "order:5m": "set ORDER_VARIANT=5m&& python scripts/order.py"
  },
  "dependencies": {
    "@polymarket/builder-relayer-client": "^0.0.8",
    "@polymarket/clob-client": "^5.8.0",
    "ethers": "^5.8.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "viem": "^2.47.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4"
  }
}
